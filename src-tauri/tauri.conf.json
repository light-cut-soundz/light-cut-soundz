{
  "productName": "LightCutSoundZ",
  "version": "0.1.7",
  "identifier": "dev.lightcutsoundz",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LightCutSoundZ",
        "width": 960,
        "height": 700,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**", "/Volumes/**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFCOUQzREM4OUJBNjFCRTgKUldUb0c2YWJ5RDJkRzVUcFZNVlk4QlVuQW5IeEppbk1yZzc4UUpJQk9SbHF4dFl4Q2FONmhjRFAK",
      "endpoints": [
        "https://github.com/light-cut-soundz/light-cut-soundz/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/ffmpeg"]
  }
}
